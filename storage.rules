rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user owns the file
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper function to check if email is verified
    function isEmailVerified() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }

    // Helper function to validate image files
    function isValidImage() {
      return request.resource.contentType.matches('image/.*')
        && request.resource.size < 2 * 1024 * 1024; // 2MB max
    }

    // ============== Profile Images ==============
    // Path: Profile/{userId}/profile.jpg
    match /Profile/{userId}/profile.jpg {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isEmailVerified() && isValidImage();
      allow delete: if isOwner(userId) && isEmailVerified();
    }

    // ============== Profile Signatures ==============
    // Path: Profile/{userId}/signature.jpg
    match /Profile/{userId}/signature.jpg {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isEmailVerified() && isValidImage();
      allow delete: if isOwner(userId) && isEmailVerified();
    }

    // Legacy signature path (png)
    match /Profile/{userId}/signature.png {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isEmailVerified() && isValidImage();
      allow delete: if isOwner(userId) && isEmailVerified();
    }

    // ============== Site Images ==============
    // Path: Profile/{ownerUID}/Sites/{siteId}/site.jpg
    match /Profile/{ownerUID}/Sites/{siteId}/site.jpg {
      // Only owner can read/write their site images
      allow read: if isOwner(ownerUID);
      allow write: if isOwner(ownerUID) && isEmailVerified() && isValidImage();
      allow delete: if isOwner(ownerUID) && isEmailVerified();

      // TODO: Add shared user read access
      // - Check Firestore for sharedWith permissions
      // - VIEW, FIXER, CONTRIBUTOR can read
    }

    // ============== Snag Problem Photos ==============
    // Path: Profile/{ownerUID}/Sites/{siteId}/Snags/{snagId}/{fileName}
    match /Profile/{ownerUID}/Sites/{siteId}/Snags/{snagId}/{fileName} {
      // Only owner can read/write snag images
      allow read: if isOwner(ownerUID);
      allow write: if isOwner(ownerUID) && isEmailVerified() && isValidImage();
      allow delete: if isOwner(ownerUID) && isEmailVerified();

      // TODO: Add shared user access
      // - FIXER can read/write assigned snags
      // - CONTRIBUTOR can read/write all snags
      // - VIEW can only read
    }

    // ============== Snag Fix Photos ==============
    // Path: Profile/{ownerUID}/Sites/{siteId}/Snags/{snagId}/fix/{fileName}
    match /Profile/{ownerUID}/Sites/{siteId}/Snags/{snagId}/fix/{fileName} {
      // Only owner can read/write fix images
      allow read: if isOwner(ownerUID);
      allow write: if isOwner(ownerUID) && isEmailVerified() && isValidImage();
      allow delete: if isOwner(ownerUID) && isEmailVerified();

      // TODO: Add shared user access for fixers
    }

    // ============== Block all other access ==============
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
