rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to check if email is verified
    function isEmailVerified() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }

    // Helper function to validate site data
    function isValidSiteData() {
      let data = request.resource.data;
      return data.name is string
          && data.name.size() > 0
          && data.name.size() <= 200                      // Max 200 chars
          && data.ownerUID == request.auth.uid            // Must match authenticated user
          && data.ownerEmail == request.auth.token.email  // Must match authenticated email
          && data.ownerEmail is string
          && data.ownerEmail.size() > 0;
    }

    // Profile collection rules
    match /Profile/{userId} {
      // Users can read their own profile (even if it doesn't exist yet)
      allow read: if isOwner(userId);
      
      // Users can create their own profile if email is verified
      allow create: if isOwner(userId) && isEmailVerified();
      
      // Users can update their own profile if email is verified
      allow update: if isOwner(userId) && isEmailVerified();
      
      // Users cannot delete profiles (for data integrity)
      allow delete: if false;
      
      // Sites subcollection
      match /Sites/{siteId} {
        // Owner can read their own sites
        allow read: if isOwner(userId);

        // Owner can create sites with valid data
        allow create: if isOwner(userId)
                      && isEmailVerified()
                      && isValidSiteData();

        // Owner can update their own sites
        allow update: if isOwner(userId)
                      && isEmailVerified()
                      && isValidSiteData();

        // Owner can delete their own sites
        allow delete: if isOwner(userId) && isEmailVerified();
        // TODO: Add shared user access logic
        // - Check sharedWith map for user's email
        // - VIEW: read only
        // - FIXER: read + update assigned snags
        // - CONTRIBUTOR: read + write sites and snags

        // Snags subcollection
        match /Snags/{snagId} {
          allow read: if isOwner(userId);
          allow write: if isOwner(userId) && isEmailVerified();
          // TODO: Add shared user access for snags
        }
      }
    }
    
    // Storage rules for profile images would go in storage.rules
    // These are just the Firestore rules
  }
}


