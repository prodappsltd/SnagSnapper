{
  "rules": {
    "device_sessions": {
      "$userId": {
        ".read": "auth != null && $userId === auth.uid",
        ".write": "auth != null && $userId === auth.uid",

        "current_device": {
          ".validate": "newData.hasChildren(['device_id', 'device_name', 'last_active'])",

          "device_id": {
            ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 100"
          },
          "device_name": {
            ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 100"
          },
          "last_active": {
            ".validate": "newData.isNumber() && newData.val() <= now + 60000"
          },
          "session_start": {
            ".validate": "newData.isNumber() && newData.val() <= now + 60000"
          },
          "force_logout": {
            ".validate": "newData.isBoolean()"
          },
          "$other": { ".validate": false }
        },

        "force_logout_before": {
          ".validate": "newData.isNumber() && newData.val() <= now + 60000"
        },

        "$other": { ".validate": false }
      }
    },

    ".read": false,
    ".write": false
  }
}
