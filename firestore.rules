rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================================
    // HELPER FUNCTIONS
    // ============================================================================

    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if user owns the document (by UID in path)
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if email is verified
    function isEmailVerified() {
      return isAuthenticated() && request.auth.token.email_verified == true;
    }

    // Get user's email (lowercase)
    function getUserEmail() {
      return request.auth.token.email.lower();
    }

    // Check if user is a collaborator on the site (email in sharedWith)
    function isCollaborator(siteData) {
      return isAuthenticated()
          && getUserEmail() in siteData.sharedWith;
    }

    // Get user's permission level on a site
    function getPermission(siteData) {
      return siteData.sharedWith[getUserEmail()];
    }

    // Check if user has specific permission
    function hasPermission(siteData, permission) {
      return isCollaborator(siteData) && getPermission(siteData) == permission;
    }

    // Check if user can view (any collaborator can view)
    function canView(siteData) {
      return isCollaborator(siteData);
    }

    // Check if user can contribute (CONTRIBUTOR permission)
    function canContribute(siteData) {
      return hasPermission(siteData, 'CONTRIBUTOR');
    }

    // Validate site data for create/update
    function isValidSiteData() {
      let data = request.resource.data;
      return data.name is string
          && data.name.size() > 0
          && data.name.size() <= 200
          && data.ownerUID == request.auth.uid
          && data.ownerEmail == request.auth.token.email
          && data.ownerEmail is string
          && data.ownerEmail.size() > 0;
    }

    // Ensure ownership fields are not changed
    function ownershipUnchanged() {
      return request.resource.data.ownerUID == resource.data.ownerUID
          && request.resource.data.ownerEmail == resource.data.ownerEmail;
    }

    // ============================================================================
    // SNAG VALIDATION FUNCTIONS
    // SYNC: These constraints must match UI validation in create_snag_v2.dart
    // ============================================================================

    // Validate snag data for create/update
    function isValidSnagData() {
      let data = request.resource.data;
      return // Required string fields
             data.title is string && data.title.size() == 0
          && data.siteUID is string && data.siteUID.size() > 0 && data.siteUID.size() <= 50
          && data.ownerEmail is string && data.ownerEmail.size() > 0 && data.ownerEmail.size() <= 254
          && data.creatorEmail is string && data.creatorEmail.size() > 0 && data.creatorEmail.size() <= 254
          // Required boolean fields
          && data.snagStatus is bool
          && data.snagConfirmedStatus is bool
          // Required timestamp fields
          && data.creationDate is timestamp
          && data.updatedAt is timestamp
          // Required integer fields
          && data.rejectionCount is int && data.rejectionCount >= 0
          && data.firebaseVersion is int && data.firebaseVersion >= 0
          // Required list fields (6 slots each, strings max 500 chars)
          && data.imagePaths is list && data.imagePaths.size() == 6
          && data.imagePaths[0] is string && data.imagePaths[0].size() <= 500
          && data.imagePaths[1] is string && data.imagePaths[1].size() <= 500
          && data.imagePaths[2] is string && data.imagePaths[2].size() <= 500
          && data.imagePaths[3] is string && data.imagePaths[3].size() <= 500
          && data.imagePaths[4] is string && data.imagePaths[4].size() <= 500
          && data.imagePaths[5] is string && data.imagePaths[5].size() <= 500
          && data.fixImagePaths is list && data.fixImagePaths.size() == 6
          && data.fixImagePaths[0] is string && data.fixImagePaths[0].size() <= 500
          && data.fixImagePaths[1] is string && data.fixImagePaths[1].size() <= 500
          && data.fixImagePaths[2] is string && data.fixImagePaths[2].size() <= 500
          && data.fixImagePaths[3] is string && data.fixImagePaths[3].size() <= 500
          && data.fixImagePaths[4] is string && data.fixImagePaths[4].size() <= 500
          && data.fixImagePaths[5] is string && data.fixImagePaths[5].size() <= 500
          // Optional string fields (null or string with max length)
          && (data.description == null || (data.description is string && data.description.size() <= 5000))
          && (data.location == null || (data.location is string && data.location.size() <= 200))
          && (data.asset == null || (data.asset is string && data.asset.size() <= 200))
          && (data.priority == null || (data.priority is string && data.priority.size() <= 4))
          && (data.snagCategory == null || (data.snagCategory is string && data.snagCategory.size() <= 100))
          && (data.assignedEmail == null || (data.assignedEmail is string && data.assignedEmail.size() <= 254))
          && (data.assignedName == null || (data.assignedName is string && data.assignedName.size() <= 100))
          && (data.snagFixDescription == null || (data.snagFixDescription is string && data.snagFixDescription.size() <= 5000))
          && (data.lastModifiedBy == null || (data.lastModifiedBy is string && data.lastModifiedBy.size() <= 254))
          && (data.rejectionReason == null || (data.rejectionReason is string && data.rejectionReason.size() <= 500))
          // Optional timestamp fields
          && (data.dueDate == null || data.dueDate is timestamp)
          && (data.lastModifiedDate == null || data.lastModifiedDate is timestamp)
          && (data.completedDate == null || data.completedDate is timestamp)
          // Optional number fields
          && (data.costEstimate == null || data.costEstimate is number);
    }

    // Ensure snag identity fields are not changed after creation
    function snagIdentityUnchanged() {
      return request.resource.data.siteUID == resource.data.siteUID
          && request.resource.data.ownerEmail == resource.data.ownerEmail
          && request.resource.data.creatorEmail == resource.data.creatorEmail
          && request.resource.data.creationDate == resource.data.creationDate;
    }

    // ============================================================================
    // PROFILE COLLECTION
    // Path: /Profile/{ownerUID}
    // ============================================================================

    match /Profile/{ownerUID} {
      // Users can read their own profile
      allow read: if isOwner(ownerUID);

      // Users can create their own profile if email is verified
      allow create: if isOwner(ownerUID) && isEmailVerified();

      // Users can update their own profile if email is verified
      allow update: if isOwner(ownerUID) && isEmailVerified();

      // Users cannot delete profiles (for data integrity)
      allow delete: if false;

      // ----------------------------------------
      // SITES SUBCOLLECTION
      // Path: /Profile/{ownerUID}/Sites/{siteId}
      // ----------------------------------------
      match /Sites/{siteId} {
        // Owner has full access
        allow read: if isOwner(ownerUID);

        allow create: if isOwner(ownerUID)
                      && isEmailVerified()
                      && isValidSiteData();

        allow update: if isOwner(ownerUID)
                      && isEmailVerified()
                      && isValidSiteData();

        allow delete: if isOwner(ownerUID) && isEmailVerified();

        // Collaborators can read if their email is in sharedWith
        allow read: if canView(resource.data);

        // CONTRIBUTOR can update (but not delete or change ownership)
        allow update: if canContribute(resource.data)
                      && isEmailVerified()
                      && ownershipUnchanged()
                      // Cannot modify sharedWith (only owner can)
                      && request.resource.data.sharedWith == resource.data.sharedWith;

        // ----------------------------------------
        // SNAGS SUBCOLLECTION
        // Path: /Profile/{ownerUID}/Sites/{siteId}/Snags/{snagId}
        // ----------------------------------------
        match /Snags/{snagId} {
          // Owner can read any snag
          allow read: if isOwner(ownerUID);

          // Owner can create snags with valid data
          allow create: if isOwner(ownerUID)
                        && isEmailVerified()
                        && isValidSnagData();

          // Owner can update snags with valid data, identity fields unchanged
          allow update: if isOwner(ownerUID)
                        && isEmailVerified()
                        && isValidSnagData()
                        && snagIdentityUnchanged();

          // Only owner can delete snags
          allow delete: if isOwner(ownerUID) && isEmailVerified();

          // Collaborators can read if they can view the site
          allow read: if canView(get(/databases/$(database)/documents/Profile/$(ownerUID)/Sites/$(siteId)).data);

          // CONTRIBUTOR can create snags with valid data
          allow create: if canContribute(get(/databases/$(database)/documents/Profile/$(ownerUID)/Sites/$(siteId)).data)
                        && isEmailVerified()
                        && isValidSnagData();

          // CONTRIBUTOR can update snags with valid data, identity unchanged
          // WORKING can update only assigned snags
          allow update: if isEmailVerified()
                        && isValidSnagData()
                        && snagIdentityUnchanged()
                        && (
                          // CONTRIBUTOR can update any snag
                          canContribute(get(/databases/$(database)/documents/Profile/$(ownerUID)/Sites/$(siteId)).data)
                          // WORKING can update only if assigned to them
                          || (hasPermission(get(/databases/$(database)/documents/Profile/$(ownerUID)/Sites/$(siteId)).data, 'WORKING')
                              && resource.data.assignedEmail == getUserEmail())
                        );
        }
      }
    }

    // ============================================================================
    // SHARED_ACCESS COLLECTION (Discovery index - Cloud Function managed)
    // Single document per user: /shared_access/{emailHash}
    // Document structure: { email: "user@example.com", sites: { siteId: ownerUID, ... } }
    // ============================================================================

    match /shared_access/{emailHash} {
      // User can ONLY read their own shared_access document
      // Cloud Function stores email field for verification
      // Uses get() instead of list() - security rules work correctly
      allow read: if isAuthenticated()
                  && resource.data.email == request.auth.token.email.lower();

      // Only Cloud Functions can write (no client writes allowed)
      allow write: if false;
    }

    // ============================================================================
    // DEVICE SESSIONS (for single-device enforcement)
    // ============================================================================

    match /device_sessions/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId);
    }
  }
}
